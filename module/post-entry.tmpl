<article class="bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-shadow p-6 mb-6">
  {{- if and .thumbnail (eq $.settings.show_post_thumbnail "true") }}
  <a href="{{ .fullPath }}">
    <img src="{{ .thumbnail }}" alt="{{ .title }}" class="w-full h-48 object-cover rounded-lg mb-4">
  </a>
  {{- end }}

  <h2 class="text-2xl font-bold mb-2">
    <a href="{{ .fullPath }}" class="text-gray-900 dark:text-white hover:text-gray-600 dark:hover:text-gray-300">
      {{ .title }}
    </a>
  </h2>

  <div class="flex items-center space-x-4 text-sm text-gray-600 dark:text-gray-400 mb-4">
    <time datetime="{{ .createTime }}">{{ .createTime | date "2006-01-02" }}</time>
    {{- if .categories }}
    <span>·</span>
    <div class="flex items-center space-x-2">
      {{- range .categories }}
      <a href="{{ .fullPath }}" class="hover:text-gray-900 dark:hover:text-white">{{ .name }}</a>
      {{- end }}
    </div>
    {{- end }}
  </div>

  {{- if .summary }}
  <p class="text-gray-700 dark:text-gray-300 mb-4">{{ .summary }}</p>
  {{- end }}

  <div class="flex items-center justify-between">
    <a href="{{ .fullPath }}" class="text-sm text-gray-900 dark:text-white hover:underline">
      阅读更多 →
    </a>
    {{- if .tags }}
    <div class="flex items-center space-x-2">
      {{- range .tags }}
      <a href="{{ .fullPath }}" class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 dark:hover:bg-gray-600">
        #{{ .name }}
      </a>
      {{- end }}
    </div>
    {{- end }}
  </div>
</article>
